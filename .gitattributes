# Default to LF for everything, with platform-aware conversion on checkout.
* text=auto eol=lf

# Sources
*.ino   text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.c     text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.sh    text eol=lf

# Binary EDA / CAD assets
*.zip       binary
*.xlsx      binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.JPG       binary
*.JPEG      binary
*.gif       binary
*.PNG       binary
*.uf2       binary
*.bin       binary
*.hex       binary
*.kicad_pcb binary
*.kicad_sch binary
